# Copy to .env to override the defaults. .env is not committed.
# All values below are the built-in defaults, shown here for reference.

REQUEST_TIMEOUT=5s
DOWN_CONFIRM_ATTEMPTS=2
DOWN_CONFIRM_DELAY=1s
UP_CONFIRM_ATTEMPTS=1
UP_CONFIRM_DELAY=10s

# Telegram alerts. Set both to enable; leave empty to skip the channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
